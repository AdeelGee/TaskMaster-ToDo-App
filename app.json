{
  "expo": {
    "name": "TaskMaster-ToDo-App",
    "slug": "taskmaster-ToDo-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/goal.png",
    "scheme": "taskmaster",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#3A3A38",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/goal.png",
        "backgroundColor": "#3A3A38"
      },
      "permissions": [
        "NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/goal.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#3A3A38"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/goal.png",
          "color": "#3A3A38"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
